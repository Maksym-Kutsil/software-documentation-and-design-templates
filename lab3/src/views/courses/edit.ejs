<%- include('../partials/header') %>

<div class="page-header">
    <h1>Edit course #<%= course.id %></h1>
    <a href="/courses/<%= course.id %>" class="btn btn-outline">Cancel</a>
</div>

<% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
        <strong>Будь ласка, виправте помилки:</strong>
        <ul>
            <% errors.forEach(function(err) { %>
                <li><%= err %></li>
            <% }) %>
        </ul>
    </div>
<% } %>

<form method="POST" action="/courses/<%= course.id %>/edit" class="form">
    <label>
        <span>Name</span>
        <input type="text" name="name" value="<%= values.name || '' %>" required />
    </label>

    <label>
        <span>Description</span>
        <textarea name="description" rows="4" required><%= values.description || '' %></textarea>
    </label>

    <label>
        <span>Duration (weeks)</span>
        <input type="number" name="durationWeeks" min="1" max="52" value="<%= values.durationWeeks %>" required />
    </label>

    <label>
        <span>Specialization</span>
        <select name="specializationId" required>
            <% specializations.forEach(function(s) { %>
                <option value="<%= s.id %>" <%= Number(values.specializationId) === s.id ? 'selected' : '' %>><%= s.name %></option>
            <% }) %>
        </select>
    </label>

    <label>
        <span>Instructor</span>
        <select name="instructorId" required>
            <% instructors.forEach(function(i) { %>
                <option value="<%= i.id %>" <%= Number(values.instructorId) === i.id ? 'selected' : '' %>><%= i.name %></option>
            <% }) %>
        </select>
    </label>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save</button>
        <a href="/courses/<%= course.id %>" class="btn btn-outline">Cancel</a>
    </div>
</form>

<%- include('../partials/footer') %>
