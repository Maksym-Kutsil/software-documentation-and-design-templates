<%- include('../partials/header') %>

<div class="page-header">
    <h1>Delete course</h1>
    <a href="/courses/<%= course.id %>" class="btn btn-outline">Cancel</a>
</div>

<div class="alert alert-warning">
    <strong>Ви впевнені, що хочете видалити цей курс?</strong>
    <p>Цю дію не можна буде скасувати.</p>
</div>

<div class="detail-grid">
    <div class="detail-row">
        <span class="label">ID</span>
        <span><%= course.id %></span>
    </div>
    <div class="detail-row">
        <span class="label">Name</span>
        <span><%= course.name %></span>
    </div>
    <div class="detail-row">
        <span class="label">Specialization</span>
        <span><%= course.specializationName || '—' %></span>
    </div>
    <div class="detail-row">
        <span class="label">Instructor</span>
        <span><%= course.instructorName || '—' %></span>
    </div>
</div>

<form method="POST" action="/courses/<%= course.id %>/delete" class="form-actions">
    <button type="submit" class="btn btn-danger">Yes, delete</button>
    <a href="/courses/<%= course.id %>" class="btn btn-outline">No, cancel</a>
</form>

<%- include('../partials/footer') %>
